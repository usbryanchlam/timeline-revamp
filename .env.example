# MapTiler vector tiles for the cinematic reel.
# Sign up at https://www.maptiler.com/ (free tier: 100k tile requests/month)
# and paste your key into .env.local (NOT this file). Without a key the app
# falls back to https://demotiles.maplibre.org/ for offline-friendly dev.
VITE_MAPTILER_KEY=

# Backend (server/) — copy to .env.local and fill in.
DATABASE_URL=postgres://timeline:timeline_dev_pw@localhost:5432/timeline
POSTGRES_PASSWORD=timeline_dev_pw
PORT=8787

# Auth0 — wired in plan 04-02. Leave blank for 04-01.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=
