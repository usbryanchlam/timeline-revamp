# MapTiler vector tiles for the cinematic reel.
# Sign up at https://www.maptiler.com/ (free tier: 100k tile requests/month)
# and paste your key into .env.local (NOT this file). Without a key the app
# falls back to https://demotiles.maplibre.org/ for offline-friendly dev.
VITE_MAPTILER_KEY=

# Backend (server/) — copy to .env.local and fill in.
DATABASE_URL=postgres://timeline:timeline_dev_pw@localhost:5432/timeline
POSTGRES_PASSWORD=timeline_dev_pw
PORT=8787

# Auth0 — get values from your Auth0 dashboard.
# Server-side (read by server/env.ts via dotenv):
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.timeline.bryanlam.dev
AUTH0_CLIENT_ID=<spa-client-id>

# Frontend (read by import.meta.env via Vite — VITE_ prefix is required):
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=<spa-client-id>
VITE_AUTH0_AUDIENCE=https://api.timeline.bryanlam.dev

# Phase 6: OCI Object Storage (photo upload pipeline)
# OCI Console → Profile → Tenancy → OCID
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxxx
# OCI Console → Identity → Users → your user → OCID
OCI_USER_OCID=ocid1.user.oc1..xxxx
# OCI Console → User → API Keys → fingerprint of added key
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
# Local filesystem path to PEM file (gitignored — e.g., ~/.oci/timeline-revamp.pem)
OCI_PRIVATE_KEY_PATH=/Users/<you>/.oci/timeline-revamp.pem
# OCI region identifier (e.g., us-sanjose-1, us-phoenix-1)
OCI_REGION=us-sanjose-1
# OCI Console → Object Storage → Bucket → Namespace
OCI_NAMESPACE=<namespace>
# OCI bucket name created for photos (public-read visibility on objects)
OCI_BUCKET_NAME=timeline-photos
